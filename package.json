{
	"name": "homepage",
	"version": "7.0.0",
	"private": true,
	"type": "module",
	"homepage": "https://github.com/rejas/",
	"author": {
		"name": "rejas",
		"url": "https://github.com/rejas/"
	},
	"pre-push": [
		"test"
	],
	"scripts": {
		"--- MAIN SCRIPTS ---": "------------------------------------------------------------",
		"start": "pnpm run dev",
		"test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 0",
		"--- ASTRO SCRIPTS ---": "----------------------------------------------------------",
		"dev": "astro dev",
		"build": "astro build",
		"preview": "pnpm run netlify:serve",
		"astro": "astro",
		"--- NETLIFY SCRIPTS ---": "--------------------------------------------------------",
		"netlify:init": "netlify init",
		"netlify:build": "netlify build",
		"netlify:serve": "netlify serve",
		"--- NPM SCRIPTS ---": "-------------------------------------------------------------",
		"format": "prettier --write --ignore-unknown *.{js,json} \"src/**/*.{astro,css,js,jsx,mdx}\"",
		"prepare": "husky",
		"pre-commit": "lint-staged"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.3",
		"@astrojs/netlify": "^7.0.8",
		"@astrojs/react": "^5.0.3",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@fontsource/josefin-sans": "^5.2.8",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.1.7",
		"astro-opengraph-images": "^1.14.3",
		"astro-seo": "^1.1.0",
		"beanheads": "^0.3.3",
		"github-webcomponents": "^1.3.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tw-to-css": "^0.0.12"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@rollup/plugin-yaml": "^4.1.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"eslint-plugin-astro": "^1.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"netlify-cli": "^24.11.3",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"sharp": "^0.34.5"
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	}
}
