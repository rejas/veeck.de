{
	"name": "homepage",
	"version": "7.0.0",
	"private": true,
	"type": "module",
	"homepage": "https://github.com/rejas/",
	"author": {
		"name": "rejas",
		"url": "https://github.com/rejas/"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.15.0",
	"scripts": {
		"--- MAIN SCRIPTS ---": "------------------------------------------------------------",
		"start": "pnpm run dev",
		"--- ASTRO SCRIPTS ---": "----------------------------------------------------------",
		"dev": "astro dev",
		"build": "astro build",
		"check": "astro check",
		"lint": "eslint .",
		"preview": "pnpm run netlify:serve",
		"astro": "astro",
		"--- NETLIFY SCRIPTS ---": "--------------------------------------------------------",
		"netlify:init": "pnpm dlx netlify-cli init",
		"netlify:build": "pnpm dlx netlify-cli build",
		"netlify:serve": "pnpm dlx netlify-cli serve",
		"--- NPM SCRIPTS ---": "-------------------------------------------------------------",
		"format": "prettier --write --ignore-unknown *.{js,json} \"src/**/*.{astro,css,js,jsx,mdx}\"",
		"format:check": "prettier --check --ignore-unknown *.{js,json} \"src/**/*.{astro,css,js,jsx,mdx}\"",
		"update:deps": "pnpx npm-check-updates -c 1d -i --format group",
		"prepare": "husky",
		"postinstall": "node -e \"try { require('fs').chmodSync('node_modules/prettier/bin/prettier.cjs', 0o755) } catch {}\"",
		"pre-commit": "lint-staged"
	},
	"dependencies": {
		"@astrojs/mdx": "^7.0.3",
		"@astrojs/netlify": "^8.1.2",
		"@astrojs/react": "^6.0.1",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource/josefin-sans": "^5.3.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"astro": "^7.1.1",
		"astro-opengraph-images": "^1.17.1",
		"astro-seo": "^1.1.0",
		"beanheads": "^0.3.3",
		"github-webcomponents": "^1.3.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tw-to-css": "^0.0.12"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@rollup/plugin-yaml": "^5.0.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"eslint": "^10.7.0",
		"eslint-plugin-astro": "^3.0.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.1.0",
		"prettier": "^3.9.5",
		"prettier-plugin-astro": "^0.14.1",
		"sharp": "^0.35.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0"
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	}
}
