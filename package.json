{
	"name": "homepage",
	"version": "7.0.0",
	"private": true,
	"type": "module",
	"homepage": "https://github.com/rejas/",
	"author": {
		"name": "rejas",
		"url": "https://github.com/rejas/"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.8.0",
	"scripts": {
		"--- MAIN SCRIPTS ---": "------------------------------------------------------------",
		"start": "pnpm run dev",
		"--- ASTRO SCRIPTS ---": "----------------------------------------------------------",
		"dev": "astro dev",
		"build": "astro build",
		"check": "astro check",
		"lint": "eslint .",
		"preview": "pnpm run netlify:serve",
		"astro": "astro",
		"--- NETLIFY SCRIPTS ---": "--------------------------------------------------------",
		"netlify:init": "netlify init",
		"netlify:build": "netlify build",
		"netlify:serve": "netlify serve",
		"--- NPM SCRIPTS ---": "-------------------------------------------------------------",
		"format": "prettier --write --ignore-unknown *.{js,json} \"src/**/*.{astro,css,js,jsx,mdx}\"",
		"format:check": "prettier --check --ignore-unknown *.{js,json} \"src/**/*.{astro,css,js,jsx,mdx}\"",
		"update:deps": "pnpx npm-check-updates -c 1d -i --format group",
		"prepare": "husky",
		"pre-commit": "lint-staged"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.4",
		"@astrojs/netlify": "^7.0.13",
		"@astrojs/react": "^5.0.7",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource/josefin-sans": "^5.2.8",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.4.8",
		"astro-opengraph-images": "^1.16.1",
		"astro-seo": "^1.1.0",
		"beanheads": "^0.3.3",
		"github-webcomponents": "^1.3.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tw-to-css": "^0.0.12"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@rollup/plugin-yaml": "^4.1.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"eslint": "^10.5.0",
		"eslint-plugin-astro": "^1.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"netlify-cli": "^26.1.0",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1",
		"sharp": "^0.34.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1"
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	}
}
