---
import { type CollectionEntry, getCollection } from 'astro:content';

import '../../styles/content.css';

import GalleryGrid from '../../components/GalleryGrid.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import Icon from '../../components/Icon.astro';
import Lightbox from '../../components/Lightbox.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'galleries'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const galleries = await getCollection('galleries');
	return galleries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;

const last_modified = entry.data.last_modified
	? entry.data.last_modified.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })
	: '';
---

<BaseLayout accent="amber" title={entry.data.title} description={entry.data.lead} last_modified={last_modified}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/photos/"><Icon icon="arrow-left" /> Galleries</a>
					<CategoryHero
						title={entry.data.title}
						tagline={entry.data.lead}
						image={entry.data.img}
						imageAlt={entry.data.img_alt || ''}
					/>
				</div>
			</header>
			<main class="wrapper stack gap-15">
				<div class="stack gap-10 content"></div>
				<GalleryGrid gallery={entry} />
			</main>
		</div>
	</div>
	<Lightbox />
</BaseLayout>
