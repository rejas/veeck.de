---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import PortfolioPreview from '../components/previews/PortfolioPreview.astro';
import CategoryHero from '../components/CategoryHero.astro';
import heroImage from '../images/categories/projects.jpg';
import Grid from '../components/Grid.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.first_published.valueOf() - a.data.first_published.valueOf(),
);
---

<BaseLayout accent="green" title="My Projects | Veeck" description="Learn about Veeck's most recent projects">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<CategoryHero
				title="My projects"
				tagline="all the techy nerdy geeky stuff I do for fun"
				image={heroImage}
				imageAlt="A wall of Omron relays"
			/>
			<Grid variant="offset">
				<github-card user="rejas"></github-card>
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
	</div>
</BaseLayout>

<script>
	// Import and define your web component here
	import 'github-webcomponents';
</script>
