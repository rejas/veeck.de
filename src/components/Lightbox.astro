---
// Unified fullscreen lightbox, shared by photo galleries and inline content
// images. It is DOM-driven: any `.lightbox-trigger` element on the page becomes
// a trigger via its data attributes:
//   data-full     — large image source (1600px, served via the Netlify image CDN)
//   data-caption  — caption text
//   data-name     — optional filename; when present, enables shareable #<filename>
//                   deep links that survive reordering
// Triggers are produced by <GalleryGrid /> (galleries) and <ContentImage /> (MDX).
---

<dialog class="lightbox" aria-label="Image viewer">
	<button type="button" class="lb-btn lb-close" aria-label="Close">✕</button>
	<button type="button" class="lb-btn lb-prev" aria-label="Previous image">‹</button>
	<figure class="lb-figure">
		<img class="lb-image" src="" alt="" />
		<figcaption class="lb-caption"></figcaption>
	</figure>
	<button type="button" class="lb-btn lb-next" aria-label="Next image">›</button>
</dialog>

<style>
	.lightbox {
		width: 100vw;
		max-width: 100vw;
		height: 100dvh;
		max-height: 100dvh;
		margin: 0;
		padding: 0;
		border: 0;
		background: transparent;
		overflow: hidden;
	}
	.lightbox::backdrop {
		background: oklch(20% 0 0 / 92%);
	}
	.lb-figure {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 100%;
		margin: 0;
		padding: 2rem;
	}
	.lb-image {
		max-width: 92vw;
		max-height: 82dvh;
		object-fit: contain;
		border-radius: 0.5rem;
	}
	.lb-caption {
		position: fixed;
		left: 50%;
		bottom: 1.25rem;
		transform: translateX(-50%);
		max-width: min(92vw, 65ch);
		margin: 0;
		color: oklch(95% 0 0);
		text-align: center;
		text-wrap: pretty;
	}
	.lb-caption:empty {
		display: none;
	}
	.lb-btn {
		position: fixed;
		display: grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		border: 0;
		border-radius: 50%;
		background: oklch(0% 0 0 / 50%);
		color: #fff;
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
	}
	.lb-btn:hover,
	.lb-btn:focus-visible {
		background: oklch(0% 0 0 / 85%);
	}
	.lb-close {
		top: 1rem;
		right: 1rem;
		cursor: zoom-out;
	}
	.lb-prev {
		top: 50%;
		left: 1rem;
		transform: translateY(-50%);
	}
	.lb-next {
		top: 50%;
		right: 1rem;
		transform: translateY(-50%);
	}
	@media (prefers-reduced-motion: no-preference) {
		.lb-image {
			animation: lb-zoom 0.25s ease;
		}
	}
	@keyframes lb-zoom {
		from {
			opacity: 0;
			transform: scale(0.97);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}
</style>

<script>
	function setupLightbox(): void {
		const dialog = document.querySelector<HTMLDialogElement>('.lightbox');
		const triggers = [...document.querySelectorAll<HTMLElement>('.lightbox-trigger')];
		if (!dialog || triggers.length === 0) return;

		const image = dialog.querySelector<HTMLImageElement>('.lb-image')!;
		const caption = dialog.querySelector<HTMLElement>('.lb-caption')!;
		const items = triggers.map((t) => ({
			src: t.dataset.full ?? '',
			caption: t.dataset.caption ?? '',
			name: t.dataset.name ?? '',
		}));
		// Manage the URL hash only when triggers carry a filename (data-name).
		const usesHash = items.some((it) => it.name);
		let current = 0;

		const setHash = (i: number): void => {
			if (usesHash && items[i].name) history.replaceState(null, '', `#${encodeURIComponent(items[i].name)}`);
		};
		const clearHash = (): void => {
			if (usesHash) history.replaceState(null, '', location.pathname + location.search);
		};

		const show = (i: number): void => {
			current = (i + items.length) % items.length;
			image.src = items[current].src;
			image.alt = items[current].caption;
			caption.textContent = items[current].caption;
			setHash(current);
		};
		const open = (i: number): void => {
			show(i);
			if (!dialog.open) dialog.showModal();
		};

		triggers.forEach((trigger, i) => trigger.addEventListener('click', () => open(i)));
		dialog.querySelector('.lb-next')!.addEventListener('click', () => show(current + 1));
		dialog.querySelector('.lb-prev')!.addEventListener('click', () => show(current - 1));
		dialog.querySelector('.lb-close')!.addEventListener('click', () => dialog.close());

		dialog.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowRight') {
				e.preventDefault();
				show(current + 1);
			} else if (e.key === 'ArrowLeft') {
				e.preventDefault();
				show(current - 1);
			}
		});

		// Click on the backdrop (outside the figure) closes the viewer.
		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) dialog.close();
		});
		dialog.addEventListener('close', clearHash);

		// Touch swipe to navigate.
		let touchStartX = 0;
		dialog.addEventListener('touchstart', (e) => {
			touchStartX = e.touches[0].clientX;
		});
		dialog.addEventListener('touchend', (e) => {
			const deltaX = e.changedTouches[0].clientX - touchStartX;
			if (deltaX > 50) show(current - 1);
			else if (deltaX < -50) show(current + 1);
		});

		// Open straight to a photo when loaded with a matching #<filename> hash.
		if (usesHash) {
			const target = decodeURIComponent(location.hash.slice(1));
			if (target) {
				const idx = items.findIndex((it) => it.name === target);
				if (idx >= 0) open(idx);
			}
		}
	}

	// The site does not use the View Transitions router, so init on DOM ready.
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupLightbox);
	} else {
		setupLightbox();
	}
</script>
